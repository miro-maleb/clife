# API keys and CLIfe environment — sourced by ~/.zshrc
# Copy to ~/.config/life-os/secrets.env and fill in real values.
# Do NOT commit this file.

# Voice transcription (cl capture --voice)
export GROQ_API_KEY=""

# Email ingestion (cl ingest)
# Maildir directory mbsync delivers kb-capture mail into.
export CL_INGEST_MAILDIR="$HOME/mail/kb-capture/Inbox"

# Other API keys (optional — used by Claude Code, agents, etc.)
# export ANTHROPIC_API_KEY=""
# export GEMINI_API_KEY=""
# export DEEPSEEK_API_KEY=""
