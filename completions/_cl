#compdef cl

_cl_areas() {
  local -a areas
  local d
  for d in $HOME/kb/projects/*/area.md(N); do
    areas+=("${${d%/area.md}##*/}")
  done
  _describe "areas" areas
}

_cl_projects() {
  local -a projs
  local d
  for d in $HOME/kb/projects/*/*/project.md(N); do
    projs+=("${${d%/project.md}##*/}")
  done
  _describe "projects" projs
}

_cl_blocks() {
  local -a bl
  local d
  for d in $HOME/kb/systems/*/blocks/*.md(N); do
    bl+=("${${d##*/}%.md}")
  done
  _describe "blocks" bl
}

_cl_systems() {
  local -a sys
  local d
  for d in $HOME/kb/systems/*/system.md(N); do
    sys+=("${${d%/system.md}##*/}")
  done
  _describe "systems" sys
}

_cl_goals() {
  local -a gl
  local d
  for d in $HOME/kb/goals/*/*.md(N); do
    gl+=("${${d##*/}%.md}")
  done
  _describe "goals" gl
}

_cl_orientations() {
  local -a orl
  local d
  for d in $HOME/kb/orientations/*.md(N); do
    orl+=("${${d##*/}%.md}")
  done
  _describe "orientations" orl
}

_cl() {
  local commands=(
    "capture:quick text or voice capture → inbox"
    "ingest:pull new email from capture maildir → inbox"
    "inbox:route inbox files"
    "projects:project review"
    "notes:notes browser"
    "review:full review pipeline"
    "tree:bird's-eye view of areas/projects"
    "show:overview for area / project / sub-project"
    "week:weekly planner"
    "pool:scheduling pool — one-off items awaiting placement"
    "agenda:today's anchor — gcal + system blocks"
    "checkin:daily review — verify what was scheduled got done/missed"
    "habits:habit dashboard — per-block streaks + done/missed history"
    "blocks:routine block editor — daily/weekly block CRUD"
    "systems:system editor — status + feeding chain CRUD"
    "goals:goal editor — year/status/marker/orientations CRUD"
    "orientations:orientation editor — status CRUD"
    "lint:check kb frontmatter against the canonical schema"
    "new:scaffold area / project / sub-project"
    "new-project:create a new project (alias)"
    "dashboard:persistent dashboard"
    "view:open an HTML view of kb/ in a native window"
  )

  if (( CURRENT == 2 )); then
    _describe "cl commands" commands
  else
    case "$words[2]" in
      capture)
        _values "capture options" \
          "--voice[voice capture]" \
          "--journal[capture to journal]" \
          "-j[capture to journal]"
        ;;
      inbox)
        _values "options" "--tui[use TUI]"
        ;;
      notes)
        _values "notes options" \
          "--orphans[only orphan notes]" \
          "--stale[only notes >90d unmodified]" \
          "--area[filter to one area]:area:" \
          "--project[filter to one project]:project:" \
          "--tag[filter to one tag]:tag:"
        ;;
      ingest)
        _values "ingest options" \
          "--dry-run[preview without writing or marking seen]"
        ;;
      projects)
        if (( CURRENT == 3 )); then
          # review flags (bare `cl projects`) OR an editor subcommand
          _values "projects subcommand / review flags" \
            "list[JSON-first list of every project (editor)]" \
            "show[one project's fields]" \
            "set[edit status/deadline/tags/goals/orientations]" \
            "new[scaffold a project into an area]" \
            "archive[move a project to ~/kb/archive]" \
            "--tui[use TUI]" \
            "--sleeping[sleeping projects]" \
            "--active[active projects]" \
            "--on-hold[on-hold projects]" \
            "--complete[complete projects]" \
            "--abandoned[abandoned projects]" \
            "--all[all projects]" \
            "--json[emit active + on-hold projects as JSON (hot bar)]"
        else
          case "$words[3]" in
            show|archive) _cl_projects ;;
            set)
              if (( CURRENT == 4 )); then
                _cl_projects
              else
                _values "set options" \
                  "--status[lifecycle status]:status:(active on-hold sleeping complete abandoned archived superseded pending)" \
                  "--deadline[YYYY-MM-DD]:deadline:" \
                  "--goals[comma list of goal slugs]:goals:" \
                  "--orientations[comma list of orientation slugs]:orientations:" \
                  "--tags[comma list]:tags:" \
                  "--reviewed[stamp last_reviewed = today]" \
                  "--json[emit JSON]"
              fi
              ;;
            new)
              _values "new options" \
                "--project[project slug]:slug:" \
                "--area[owning area]:area:_cl_areas" \
                "--status[lifecycle status]:status:(active on-hold sleeping complete abandoned archived superseded pending)" \
                "--goals[comma list of goal slugs]:goals:" \
                "--orientations[comma list of orientation slugs]:orientations:" \
                "--tags[comma list]:tags:" \
                "--title[heading title]:title:" \
                "--json[emit JSON]"
              ;;
            list)
              _values "list options" "--json[emit JSON for surfaces]"
              ;;
          esac
        fi
        ;;
      week)
        _values "week options" \
          "--dump[print this week's bank, headless]" \
          "--json[emit the full week view model as JSON (surfaces)]" \
          "--next[operate on next week]" \
          "--offset[operate N weeks from now]:offset:" \
          "--place[schedule BLOCK DAY TIME]:block:" \
          "--skip[log a skip: BLOCK DAY REASON]:block:" \
          "--fill[auto-place a day's unplaced daily blocks at their default_start]:day:(mon tue wed thu fri sat sun)" \
          "--move[retime a placed block: BLOCK DAY TIME]:block:" \
          "--unplace[remove a placed block's event, back to the tray: BLOCK DAY]:block:" \
          "--duration[with --place/--move: override block duration in minutes]:minutes:"
        ;;
      pool)
        if (( CURRENT == 3 )); then
          _values "pool subcommand" \
            "add[add a one-off item]" \
            "list[list pool items]" \
            "place[record a placement (no gcal write)]" \
            "schedule[place an item AND write the gcal event]" \
            "done[mark a placement done]" \
            "return[return a missed placement to the pool]" \
            "drop[drop an item]" \
            "stage[soft-assign an item to a target day]" \
            "suggest[AI-structure a freeform capture into a schedulable item]" \
            "show[show one item + its placements]"
        else
          case "$words[3]" in
            add)
              _values "pool add options" \
                "--area[area]:area:" \
                "--project[project]:project:" \
                "--est[estimated duration: 90, 90m, 2h]:est:" \
                "--deadline[YYYY-MM-DD]:deadline:" \
                "--priority[priority int]:priority:" \
                "--calendar[gcal calendar]:calendar:" \
                "--source[kb path it came from]:source:" \
                "--note[freeform note]:note:"
              ;;
            list)
              _values "pool list options" \
                "--status[filter to one status]:status:(pooled placed done dropped)" \
                "--all[include done + dropped]" \
                "--area[area]:area:" \
                "--project[project]:project:" \
                "--json[emit JSON for surfaces]"
              ;;
            schedule)
              _values "pool schedule options" \
                "--calendar[override calendar]:calendar:" \
                "--duration[override duration: 90, 90m, 2h]:duration:"
              ;;
            stage)
              _values "pool stage options" \
                "--clear[remove the staged day]" \
                "--json[emit JSON for surfaces]"
              ;;
          esac
        fi
        ;;
      agenda)
        _values "agenda options" \
          "--dump[print today, headless]" \
          "--date[operate on YYYY-MM-DD]:date:"
        ;;
      checkin)
        _values "checkin options" \
          "--dump[print today's plan + verdicts]" \
          "--json[emit JSON for surfaces]" \
          "--full[with --json: include the whole day, not just commitments]" \
          "--mark[record a verdict]:title: :status:(done partial missed)" \
          "--date[operate on YYYY-MM-DD]:date:"
        ;;
      habits)
        _values "habits options" \
          "--dump[print the dashboard]" \
          "--json[emit JSON for surfaces]" \
          "--days[window width in days]:days:"
        ;;
      blocks)
        if (( CURRENT == 3 )); then
          _values "blocks subcommand" \
            "list[list every block]" "show[one block + feeding chain]" \
            "new[create a block]" "set[edit a block]" "rm[delete a block]" \
            "feed[edit a system's goals/orientations]" \
            "meta[systems/goals/orientations pickers]" "calendars[writable calendars]"
        else
          case "$words[3]" in
            show|rm) _cl_blocks ;;
            feed) _cl_systems ;;
            new)
              _values "new options" \
                "--block[block slug]:slug:" "--parent[owning system]:system:" \
                "--cadence[daily|weekly]:cadence:(daily weekly)" \
                "--days[comma list or all]:days:" "--duration[e.g. 30m]:dur:" \
                "--start[HH:MM]:start:" "--instances[count]:n:" \
                "--calendar[gcal name]:cal:" "--habit[true|false]:habit:(true false)" \
                "--travel[pause|keep on Travel days]:travel:(pause keep)" \
                "--json[emit JSON]"
              ;;
            set)
              if (( CURRENT == 4 )); then
                _cl_blocks
              else
                _values "set options" \
                  "--name[rename]:slug:" "--parent[re-home]:system:" \
                  "--cadence[daily|weekly]:cadence:(daily weekly)" \
                  "--days[comma list or all]:days:" "--duration[e.g. 30m]:dur:" \
                  "--start[HH:MM]:start:" "--instances[count]:n:" \
                  "--calendar[gcal name]:cal:" "--habit[true|false]:habit:(true false)" \
                  "--travel[pause|keep on Travel days]:travel:(pause keep)" \
                  "--json[emit JSON]"
              fi
              ;;
          esac
        fi
        ;;
      systems)
        if (( CURRENT == 3 )); then
          _values "systems subcommand" \
            "list[list every system]" "show[one system + blocks]" \
            "new[create a system]" "set[edit a system]" "rm[delete a system]"
        else
          case "$words[3]" in
            show|rm) _cl_systems ;;
            new)
              _values "new options" \
                "--system[system slug]:slug:" "--status[status]:status:" \
                "--goals[comma list]:goals:" "--orientations[comma list]:orients:" \
                "--json[emit JSON]"
              ;;
            set)
              if (( CURRENT == 4 )); then
                _cl_systems
              else
                _values "set options" \
                  "--status[status]:status:" "--goals[comma list]:goals:" \
                  "--orientations[comma list]:orients:" \
                  "--superseded-by[system slug]:slug:" "--superseded-on[YYYY-MM-DD]:date:" \
                  "--json[emit JSON]"
              fi
              ;;
          esac
        fi
        ;;
      goals)
        if (( CURRENT == 3 )); then
          _values "goals subcommand" \
            "list[list every goal]" "show[one goal]" \
            "new[create a goal]" "set[edit a goal]" "rm[delete a goal]"
        else
          case "$words[3]" in
            show|rm) _cl_goals ;;
            new)
              _values "new options" \
                "--goal[goal slug]:slug:" "--year[YYYY]:year:" \
                "--status[status]:status:" "--marker[success marker]:marker:" \
                "--orientations[comma list]:orients:" "--json[emit JSON]"
              ;;
            set)
              if (( CURRENT == 4 )); then
                _cl_goals
              else
                _values "set options" \
                  "--name[rename]:slug:" "--year[YYYY]:year:" \
                  "--status[status]:status:" "--marker[success marker]:marker:" \
                  "--orientations[comma list]:orients:" "--json[emit JSON]"
              fi
              ;;
          esac
        fi
        ;;
      orientations)
        if (( CURRENT == 3 )); then
          _values "orientations subcommand" \
            "list[list every orientation]" "show[one orientation]" \
            "new[create an orientation]" "set[edit an orientation]" "rm[delete an orientation]"
        else
          case "$words[3]" in
            show|rm) _cl_orientations ;;
            new)
              _values "new options" \
                "--name[orientation slug]:slug:" "--status[status]:status:" \
                "--json[emit JSON]"
              ;;
            set)
              if (( CURRENT == 4 )); then
                _cl_orientations
              else
                _values "set options" \
                  "--name[rename]:slug:" "--status[status]:status:" \
                  "--json[emit JSON]"
              fi
              ;;
          esac
        fi
        ;;
      lint)
        _values "lint options" \
          "--fix[apply safe mechanical fixes in place]" \
          "--snapshot[write timestamped report to state file (weekly timer)]" \
          "--json[emit JSON report]" \
          "--type[restrict to one schema type]:type:(area project sub-project system block goal orientation)"
        ;;
      view)
        local -a views
        local d
        for d in $HOME/clife/views/*/view.html(N); do
          views+=("${${d%/view.html}##*/}")
        done
        _describe "views" views
        _values "view options" "--list[list available views]"
        ;;
      tree)
        _values "tree options" \
          "--full[include sub-projects, systems, goals, orientations]" \
          "--active[only active projects/systems/goals/orientations]"
        ;;
      show)
        _files
        ;;
      new)
        # Smart context: if --project is in the line, --in completes areas;
        # if --sub-project is in the line, --in completes projects.
        if [[ "${words[*]}" == *--project* ]]; then
          if [[ "$words[CURRENT-1]" == "--in" ]]; then
            _cl_areas
            return
          fi
        elif [[ "${words[*]}" == *--sub-project* ]]; then
          if [[ "$words[CURRENT-1]" == "--in" ]]; then
            _cl_projects
            return
          fi
        fi
        _values "new options" \
          "--area[create a new area]:name:" \
          "--project[create a new project]:name:" \
          "--sub-project[create a new sub-project]:name:" \
          "--goal[create a new goal]:name:" \
          "--system[create a new system]:name:" \
          "--in[parent area or project]:parent:" \
          "--year[year for --goal]:year:"
        ;;
    esac
  fi
}

_cl
