#compdef cl

_cl_areas() {
  local -a areas
  local d
  for d in $HOME/kb/projects/*/area.md(N); do
    areas+=("${${d%/area.md}##*/}")
  done
  _describe "areas" areas
}

_cl_projects() {
  local -a projs
  local d
  for d in $HOME/kb/projects/*/*/project.md(N); do
    projs+=("${${d%/project.md}##*/}")
  done
  _describe "projects" projs
}

_cl() {
  local commands=(
    "capture:quick text or voice capture → inbox"
    "ingest:pull new email from capture maildir → inbox"
    "inbox:route inbox files"
    "projects:project review"
    "notes:notes browser"
    "review:full review pipeline"
    "tree:bird's-eye view of areas/projects"
    "week:weekly planner"
    "new:scaffold area / project / sub-project"
    "new-project:create a new project (alias)"
    "dashboard:persistent dashboard"
  )

  if (( CURRENT == 2 )); then
    _describe "cl commands" commands
  else
    case "$words[2]" in
      capture)
        _values "capture options" \
          "--voice[voice capture]" \
          "--journal[capture to journal]" \
          "-j[capture to journal]"
        ;;
      inbox)
        _values "options" "--tui[use TUI]"
        ;;
      notes)
        _values "notes options" \
          "--orphans[only orphan notes]" \
          "--stale[only notes >90d unmodified]" \
          "--area[filter to one area]:area:" \
          "--project[filter to one project]:project:" \
          "--tag[filter to one tag]:tag:"
        ;;
      ingest)
        _values "ingest options" \
          "--dry-run[preview without writing or marking seen]"
        ;;
      projects)
        _values "projects options" \
          "--tui[use TUI]" \
          "--sleeping[sleeping projects]" \
          "--active[active projects]" \
          "--on-hold[on-hold projects]" \
          "--complete[complete projects]" \
          "--abandoned[abandoned projects]" \
          "--all[all projects]"
        ;;
      week)
        _values "week options" \
          "--regenerate[regenerate this week's plan]" \
          "--overwrite[regenerate this week's plan]"
        ;;
      tree)
        _values "tree options" \
          "--full[include sub-projects]" \
          "--active[only active projects]"
        ;;
      new)
        # Smart context: if --project is in the line, --in completes areas;
        # if --sub-project is in the line, --in completes projects.
        if [[ "${words[*]}" == *--project* ]]; then
          if [[ "$words[CURRENT-1]" == "--in" ]]; then
            _cl_areas
            return
          fi
        elif [[ "${words[*]}" == *--sub-project* ]]; then
          if [[ "$words[CURRENT-1]" == "--in" ]]; then
            _cl_projects
            return
          fi
        fi
        _values "new options" \
          "--area[create a new area]:name:" \
          "--project[create a new project]:name:" \
          "--sub-project[create a new sub-project]:name:" \
          "--in[parent area or project]:parent:"
        ;;
    esac
  fi
}

_cl
