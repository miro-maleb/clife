#compdef cl

_cl_areas() {
  local -a areas
  local d
  for d in $HOME/kb/projects/*/area.md(N); do
    areas+=("${${d%/area.md}##*/}")
  done
  _describe "areas" areas
}

_cl_projects() {
  local -a projs
  local d
  for d in $HOME/kb/projects/*/*/project.md(N); do
    projs+=("${${d%/project.md}##*/}")
  done
  _describe "projects" projs
}

_cl() {
  local commands=(
    "capture:quick text or voice capture → inbox"
    "ingest:pull new email from capture maildir → inbox"
    "inbox:route inbox files"
    "projects:project review"
    "notes:notes browser"
    "review:full review pipeline"
    "tree:bird's-eye view of areas/projects"
    "show:overview for area / project / sub-project"
    "week:weekly planner"
    "pool:scheduling pool — one-off items awaiting placement"
    "agenda:today's anchor — gcal + system blocks"
    "checkin:daily review — verify what was scheduled got done/missed"
    "habits:habit dashboard — per-block streaks + done/missed history"
    "new:scaffold area / project / sub-project"
    "new-project:create a new project (alias)"
    "dashboard:persistent dashboard"
    "view:open an HTML view of kb/ in a native window"
  )

  if (( CURRENT == 2 )); then
    _describe "cl commands" commands
  else
    case "$words[2]" in
      capture)
        _values "capture options" \
          "--voice[voice capture]" \
          "--journal[capture to journal]" \
          "-j[capture to journal]"
        ;;
      inbox)
        _values "options" "--tui[use TUI]"
        ;;
      notes)
        _values "notes options" \
          "--orphans[only orphan notes]" \
          "--stale[only notes >90d unmodified]" \
          "--area[filter to one area]:area:" \
          "--project[filter to one project]:project:" \
          "--tag[filter to one tag]:tag:"
        ;;
      ingest)
        _values "ingest options" \
          "--dry-run[preview without writing or marking seen]"
        ;;
      projects)
        _values "projects options" \
          "--tui[use TUI]" \
          "--sleeping[sleeping projects]" \
          "--active[active projects]" \
          "--on-hold[on-hold projects]" \
          "--complete[complete projects]" \
          "--abandoned[abandoned projects]" \
          "--all[all projects]" \
          "--json[emit projects as JSON for surfaces]"
        ;;
      week)
        _values "week options" \
          "--dump[print this week's bank, headless]" \
          "--json[emit the full week view model as JSON (surfaces)]" \
          "--next[operate on next week]" \
          "--offset[operate N weeks from now]:offset:" \
          "--place[schedule BLOCK DAY TIME]:block:" \
          "--skip[log a skip: BLOCK DAY REASON]:block:" \
          "--duration[with --place: override block duration in minutes]:minutes:"
        ;;
      pool)
        if (( CURRENT == 3 )); then
          _values "pool subcommand" \
            "add[add a one-off item]" \
            "list[list pool items]" \
            "place[record a placement (no gcal write)]" \
            "schedule[place an item AND write the gcal event]" \
            "done[mark a placement done]" \
            "return[return a missed placement to the pool]" \
            "drop[drop an item]" \
            "show[show one item + its placements]"
        else
          case "$words[3]" in
            add)
              _values "pool add options" \
                "--area[area]:area:" \
                "--project[project]:project:" \
                "--est[estimated duration: 90, 90m, 2h]:est:" \
                "--deadline[YYYY-MM-DD]:deadline:" \
                "--priority[priority int]:priority:" \
                "--calendar[gcal calendar]:calendar:" \
                "--source[kb path it came from]:source:" \
                "--note[freeform note]:note:"
              ;;
            list)
              _values "pool list options" \
                "--status[filter to one status]:status:(pooled placed done dropped)" \
                "--all[include done + dropped]" \
                "--area[area]:area:" \
                "--project[project]:project:" \
                "--json[emit JSON for surfaces]"
              ;;
            schedule)
              _values "pool schedule options" \
                "--calendar[override calendar]:calendar:" \
                "--duration[override duration: 90, 90m, 2h]:duration:"
              ;;
          esac
        fi
        ;;
      agenda)
        _values "agenda options" \
          "--dump[print today, headless]" \
          "--date[operate on YYYY-MM-DD]:date:"
        ;;
      checkin)
        _values "checkin options" \
          "--dump[print today's plan + verdicts]" \
          "--json[emit JSON for surfaces]" \
          "--mark[record a verdict]:title: :status:(done missed)" \
          "--date[operate on YYYY-MM-DD]:date:"
        ;;
      habits)
        _values "habits options" \
          "--dump[print the dashboard]" \
          "--json[emit JSON for surfaces]" \
          "--days[window width in days]:days:"
        ;;
      view)
        local -a views
        local d
        for d in $HOME/clife/views/*/view.html(N); do
          views+=("${${d%/view.html}##*/}")
        done
        _describe "views" views
        _values "view options" "--list[list available views]"
        ;;
      tree)
        _values "tree options" \
          "--full[include sub-projects, systems, goals, orientations]" \
          "--active[only active projects/systems/goals/orientations]"
        ;;
      show)
        _files
        ;;
      new)
        # Smart context: if --project is in the line, --in completes areas;
        # if --sub-project is in the line, --in completes projects.
        if [[ "${words[*]}" == *--project* ]]; then
          if [[ "$words[CURRENT-1]" == "--in" ]]; then
            _cl_areas
            return
          fi
        elif [[ "${words[*]}" == *--sub-project* ]]; then
          if [[ "$words[CURRENT-1]" == "--in" ]]; then
            _cl_projects
            return
          fi
        fi
        _values "new options" \
          "--area[create a new area]:name:" \
          "--project[create a new project]:name:" \
          "--sub-project[create a new sub-project]:name:" \
          "--goal[create a new goal]:name:" \
          "--system[create a new system]:name:" \
          "--in[parent area or project]:parent:" \
          "--year[year for --goal]:year:"
        ;;
    esac
  fi
}

_cl
